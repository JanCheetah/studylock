# OpenRouter AI API – enables AI-generated study questions and answer evaluation
VITE_OPENROUTER_API_KEY=

# Optional: enables Supabase cloud persistence once Auth UI is added/configured.
# Without these values StudyLock stays local-first in browser localStorage.
VITE_SUPABASE_URL=
# Prefer the modern publishable key. Legacy anon key also still works.
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=

# Server-only: set as a Supabase Edge Function secret, never as VITE_*.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/owl-alpha
